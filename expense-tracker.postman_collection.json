{
  "info": {
    "name": "Expense Tracker API",
    "description": "Postman collection for the Expense Tracker API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Expense",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Groceries\",\n  \"amount\": 150.50,\n  \"category\": \"FOOD\",\n  \"description\": \"Weekly grocery shopping\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v0/expenses/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v0",
            "expenses",
            "{{userId}}"
          ]
        }
      }
    },
    {
      "name": "Get All Expenses",
